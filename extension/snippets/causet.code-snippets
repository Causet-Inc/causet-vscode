      "    source_events:",
      "      - ${3:EVENT_NAME}",
      "    target:",
      "      table: ${1:metric_name}",
      "      primary_key: [bucket_start]",
      "    bucket:",
      "      field: event.ts",
      "      interval: 24h",
      "    fields:",
      "      bucket_start: TIMESTAMP",
      "      ${4:metric_count}: BIGINT",
      "    aggregates:",
      "      ${3:EVENT_NAME}:",
      "        ${4:metric_count}: { op: add, by: 1 }",
      "    partition:",
      "      strategy: range",
      "      field: bucket_start",
      "      interval: \"1 month\"",
      "      precreate: ${5:2}",
      "      retention: \"${6:24 months}\"",
      "      default_partition: true$0"
